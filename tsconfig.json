{
	"compilerOptions": {
		"strict": true,
		"module": "ESNext",
		"moduleResolution": "Bundler",
		"target": "ES2022",
		"noEmit": true,
		"skipLibCheck": true,
		"plugins": [
			{
				"name": "@effect/language-service",
				"diagnosticSeverity": {
					"leakingRequirements": "warning"
				}
			}
		]
	},
	"include": ["*.ts"]
}
